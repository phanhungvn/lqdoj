from pathlib import Path

p = Path("main.py")
s = p.read_text()

s = s.replace("import undetected_chromedriver as uc", "")
s = s.replace("import chromedriver_autoinstaller", "")

# Xóa các dòng liên quan Chrome path/libs cơ bản
lines = []
for line in s.splitlines():
    bad = [
        "chromedriver_autoinstaller",
        "uc.Chrome",
        "ChromeOptions",
        "chrome_binary",
        "binary_location",
        "LD_LIBRARY_PATH",
        "chrome/chrome",
        "verify_chrome",
    ]
    if any(x in line for x in bad):
        continue
    lines.append(line)

s = "\n".join(lines)

# Thêm import Firefox
insert = """
from selenium import webdriver
from selenium.webdriver.firefox.options import Options
"""

if "from selenium import webdriver" not in s:
    s = insert + "\n" + s

# Thay driver Chrome bằng Firefox nếu còn webdriver.Chrome
s = s.replace("webdriver.Chrome(", "webdriver.Firefox(")

# Chèn khởi tạo Firefox nếu chưa có driver =
if "webdriver.Firefox" not in s:
    s += """

options = Options()
options.add_argument("--headless")
driver = webdriver.Firefox(options=options)
"""

# Nếu có dòng driver = webdriver.Firefox() thì thêm options
s = s.replace(
    "driver = webdriver.Firefox()",
    'options = Options()\\noptions.add_argument("--headless")\\ndriver = webdriver.Firefox(options=options)'
)

p.write_text(s)
print("Đã sửa main.py sang Firefox")
